{
    "web_hosting_settings": {
        "is_login_required": true, // No account creation required for ATMOSX (Not secure)
        "is_guest_access_allowed": false, // TODO: If you want to allow guest access to your dashboard. (Not Secure)
        "settings" : {
            "is_https": false, // If you want to enable HTTPS (See documentation for CF Tunnel Integration)
            "port_number": 80, // What port you would like to host ATMOSX.
            "ratelimiting": { 
                "enabled": true, // If you want to enable ratelimiting to prevent spamming of requests.
                "window_ms": 5, // When to reset ratelimit requests per address.
                "max_requests": 125 // Max requests (Default: 500 per address in a 30_000 window)
            },
            "certification_paths": { // HTTPS Certs will be located here. If you are using CF Tunnels, ignore this.
                "private_key_path": ".../storage/policy/certificates/key.pem", 
                "certificate_path": ".../storage/policy/certificates/cert.pem"
            }
        }
    },
    // Schedules are handled with cron scheduling. (See https://crontab.guru/) for a guide.
    "internal_settings": {
        "global_update": "*/5 * * * * *",  // Default 5 seconds (This updates the global cache but websocket settings will be primary guide)
        "random_update": "*/60 * * * * *",  // Default is 60 seconds (Updates rng event data)
        "update_check": "0 */6 * * *", // Default: 6 hours (Checks for AtmosphericX updates and logs to console if outdated)
        "request_timeout": 10
    },
    "websocket_settings": {
        "maximum_connections_per_ip": 50, // Max connections to a websocket address. (Default: 25 connections)
        "priority_sockets": {
            "timeout": 2, // How often websocket cache shouldn't be sent to the clients. (Default: 2 seconds)
            "sockets": [ // Type(s) of websocket subscriptions to put in the priority sockets.
                "events", "placefiles", "manual", 
                "locations", "mesonet", "rng", "emergencies"
            ]
        },
        // Below is the same as above.
        "secondary_sockets": {
            "timeout": 30,
            "sockets": [
                "changelogs", "version", "configurations", 
                "spotter_network_feed", "storm_reports", "storm_prediction_center_mesoscale",
                "tropical_storm_tracks","wx_radio","sonde_project_weather_eye",
                "tornado","severe","nexrad_radars"
            ]
        }
    },
    // Discord webhook integration settings.
    "webhook_settings": { 
        "general_alerts": { // Generic events that you are actively listening to.
            "enabled": false,
            "discord_webhook": "DISCORD_WEBHOOK_HERE", // Webhook goes here.
            "webhook_display": "AtmosphericX (Webhook Integration)", // Name of the webhook.
            "content": "<@&ROLE_ID_HERE>", // RoleID here, if you dont want a role, leave this empty.
            "webhook_cooldown": 1 // Cooldown limit.
        },
        // Same as below
        "critical_alerts": { // Handles critical only events specified in "priority_events" in alerts.jsonc
            "enabled": false,
            "discord_webhook": "DISCORD_WEBHOOK_HERE",
            "webhook_display": "AtmosphericX (Webhook Integration)",
            "content": "<@&ROLE_ID_HERE>",
            "webhook_cooldown": 1
        },
        "misc_alerts": { // Handles all misc events such as forecasts, discussions, etc. 
            "enabled": false,
            "discord_webhook": "DISCORD_WEBHOOK_HERE",
            "webhook_display": "AtmosphericX (Webhook Integration)",
            "content": "<@&ROLE_ID_HERE>",
            "webhook_cooldown": 10
        }
    },
    "streamer_bot_settings": {
        "enabled": false,
        "address": "127.0.0.1", // Streamerbot WEBSOCKET address.
        "use_bot_account": false, // If you want to use a bot account (Must be setup in the StreamerBotClient)
        "port": 8080, // Port of the websocket
        "password": "password_here", // Optional but I would recommened setting up a password.
        "events": {
            "mesonet": false, // Mesonet Updates
            "events": false,  // Alert Updates
            "pulse_point": false, // PulsePoint Updates
            "welcome": false // Welcome message when starting ATMOSX
        }
    },
    "forecasting_services": [ // Handles all the third party forecasting services in the dashboard, feel free to add your own.
        {"title": "Composite Reflectivity (HRRR)","url": "https://www.pivotalweather.com/model.php?m=hrrr&p=refcmp_uh001h&fh=loop&r=conus&dpdt=&mc=","image": "/assets/media/dashboard/forecasting/composite-reflectivity.png"},
        {"title": "Bulk Shear (0-1km) (HRRR)","url": "https://www.pivotalweather.com/model.php?m=hrrr&p=bs01&fh=loop&r=conus&dpdt=&mc=","image": "/assets/media/dashboard/forecasting/bulk-shear.png"},
        {"title": "Surface Based Cape (HRRR)","url": "https://www.pivotalweather.com/model.php?m=hrrr&p=sbcape&fh=loop&r=conus&dpdt=&mc=","image": "/assets/media/dashboard/forecasting/surface-based-cape.png"},
        {"title": "SIGTOR Paramters (HRRR)","url": "https://www.pivotalweather.com/model.php?m=hrrr&p=stp&fh=loop&r=conus&dpdt=&mc=","image": "/assets/media/dashboard/forecasting/default-pivotal.png"},
        {"title": "SPC Mesoscale Analysis","url": "https://www.spc.noaa.gov/exper/mesoanalysis/new/viewsector.php?sector=19&parm=pmsl","image": "/assets/media/dashboard/forecasting/mesoscale-logo.png"},
        {"title": "Nexlab Clean LWIR","url": "https://weather.cod.edu/satrad/?parms=continental-conus-13-24-0-100-1&checked=map&colorbar=undefined","image": "/assets/media/dashboard/forecasting/nexlab-lwir-clean.png"},
        {"title": "Nexlab True Color Satellite","url": "https://weather.cod.edu/satrad/?parms=continental-conus-truecolor-24-0-100-1&checked=map&colorbar=undefined","image": "/assets/media/dashboard/forecasting/nexlab-true-color.png"},
        {"title": "Tropical Tidbits (GFS)","url": "https://www.tropicaltidbits.com/analysis/models/","image": "/assets/media/dashboard/forecasting/tropical-logo.png"},
        {"title": "Tropical Tidbits (RGEM)","url": "https://www.tropicaltidbits.com/analysis/models/?model=rgem&region=us","image": "/assets/media/dashboard/forecasting/tropical-logo.png"}
    ],
    "third_party_services": [ // Third party services commonly used for communication / streaming / radar.
        {"title": "Live Storm Chasing","url": "https://livestormchasing.com/","image": "/assets/media/dashboard/services/storm-live-logo.png"},
        {"title": "WeatherWise","url": "https://web.weatherwise.app/","image": "/assets/media/dashboard/services/weather-wise.png"},
        {"title": "OpenMhz","url": "https://openmhz.com/systems","image": "/assets/media/dashboard/services/open-mhz.png"},
        {"title": "Global EAS","url": "https://alerts.globaleas.org/","image": "/assets/media/dashboard/services/global-eas.png"}
    ]
}