        "Tsunami Advisory": { "primary": "rgb(80,48,160)", "secondary": "rgb(56,32,120)" },
        "Special Weather Statement": { "primary": "rgb(70,130,180)", "secondary": "rgb(45,85,130)" },
        "Default": { "primary": "rgb(56,72,88)", "secondary": "rgb(32,40,48)" }
    }
}
