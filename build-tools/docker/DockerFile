# syntax=docker/dockerfile:1

FROM ubuntu:24.04

ARG REPO=https://github.com/AtmosphericX/AtmosphericX.git
ARG BRANCH=main

ENV DEBIAN_FRONTEND=noninteractive

# -----------------------------
# System dependencies
# -----------------------------
RUN apt-get update && apt-get install -y \
    git \
    curl \
    wget \
    bash \
    ca-certificates \
    build-essential \
 && rm -rf /var/lib/apt/lists/*

# Install Node.js LTS properly (important fix)
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
 && apt-get install -y nodejs

# -----------------------------
# App setup
# -----------------------------
WORKDIR /app

RUN git clone --depth 1 --branch ${BRANCH} ${REPO} .

# Ensure scripts exist and are executable
RUN chmod +x build-tools/docker/*.sh || true

# -----------------------------
# Install dependencies (safe phase)
# -----------------------------
RUN bash build-tools/docker/docker-install.sh

# -----------------------------
# Runtime
# -----------------------------
WORKDIR /app

EXPOSE 8080

CMD ["bash", "build-tools/docker/docker-start.sh"]