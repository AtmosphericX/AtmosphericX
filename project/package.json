{
  "name": "atmosphericx",
  "version": "8.0.0.4",
  "description": "Project AtmosphericX is a web based platform and widget manager tailored for amateur weather enthusiasts, storm chasers, and anyone passionate about understanding and tracking severe weather events. It provides near realtime alerts and updates, ensuring users stay informed about critical weather conditions as they unfold.",
  "main": "dist/index.cjs",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AtmosphericX/AtmosphericX.git",
    "branch": "main"
  },
  "keywords": [
    "NWWS",
    "NOAA Weather Wire Service",
    "TypeScript",
    "XMPP",
    "Weather Data",
    "Dashboard",
    "Widgets",
    "OBS Studio",
    "Streaming",
    "NWS API",
    "National Weather Service",
    "Storm Chasing",
    "Severe Weather",
    "Realtime Alerts",
    "Meteorology",
    "Weather Enthusiasts",
    "Weather Tracking"
  ],
  "author": "KiyoWx, StarflightWx, CJ Ziegler",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/AtmosphericX/AtmosphericX/issues"
  },
  "homepage": "https://github.com/AtmosphericX/AtmosphericX#readme",
  "dependencies": {
    "@atmosx/event-product-parser": "latest",
    "@atmosx/placefile-parser": "latest",
    "@atmosx/pulse-point-wrapper": "latest",
    "@atmosx/tempest-station-wrapper": "latest",
    "@firebase/app": "0.14.7",
    "@firebase/database": "1.1.0",
    "@streamerbot/client": "1.12.2",
    "argon2": "0.44.0",
    "axios": "1.13.5",
    "better-sqlite3": "12.6.2",
    "blessed": "0.1.81",
    "croner": "10.0.1",
    "express": "5.2.1",
    "express-rate-limit": "8.2.2",
    "express-session": "1.19.0",
    "express-ws": "5.0.2",
    "jsonc-parser": "3.3.1",
    "typescript": "5.9.3"
  },
  "scripts": {
    "start": "node ./dist/index.cjs",
    "build": "tsup && node ./dist/index.cjs",
    "config": "tsup src/config.template.ts --out-dir dist/tools --format cjs --clean && node dist/config.template.cjs",
    "docs:dev": "vitepress dev docs --host --port 3000",
    "docs:build": "vitepress build docs"
  },
  "devDependencies": {
    "@types/node": "25.2.0",
    "@types/serve-static": "2.2.0",
    "chokidar": "5.0.0",
    "tsup": "8.5.1",
    "vitepress": "1.6.4"
  }
}
